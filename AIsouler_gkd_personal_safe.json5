      "key": 2,
      "name": "青少年模式-全局",
      "desc": "关闭应用的青少年模式弹窗",
      "order": -8,
      "fastQuery": true,
      "matchTime": 10000,
      "actionMaximum": 1,
      "resetMatch": "app",
      "disableIfAppGroupMatch": "青少年模式",
