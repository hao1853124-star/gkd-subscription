{
  "id": 666001,
  "name": "AIsouler的GKD订阅-个人安全版",
  "version": 406,
  "author": "AIsouler / personal-safe",
  "supportUri": "https://github.com/AIsouler/GKD_subscription/issues/new/choose",
  "categories": [
    {
      "key": 0,
      "name": "开屏广告",
      "enable": true
    },
    {
      "key": 1,
      "name": "青少年模式",
      "enable": false
    },
    {
      "key": 2,
